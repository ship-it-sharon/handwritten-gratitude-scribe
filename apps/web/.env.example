# Posy web app — environment variables
# Real values live in Vercel (Settings → Environment Variables) and in a
# local .env.local (gitignored). Never commit real values.

# Supabase project (Settings → API in the Supabase dashboard).
# Both values are public by design (the anon key is protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
